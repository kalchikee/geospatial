# ============================================================
# Chicago NDVI Pipeline — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- PostgreSQL / PostGIS ---------------------------------
POSTGRES_DB=chicago_ndvi
POSTGRES_USER=ndvi_user
POSTGRES_PASSWORD=changeme_strong_password

# ---- Copernicus Data Space (Sentinel-2) -------------------
# Register free at: https://dataspace.copernicus.eu/
CDSE_USERNAME=your_email@example.com
CDSE_PASSWORD=your_cdse_password

# ---- AWS (Landsat — OPTIONAL, skip if not using Landsat) --
# Leave blank or omit entirely to run Sentinel-2 only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-west-2
